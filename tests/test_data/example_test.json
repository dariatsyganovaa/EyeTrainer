                {"text": "Слабая (+2)", "value": "+2"},
                {"text": "Средняя (+3)", "value": "+3"},
                {"text": "Средняя (+4)", "value": "+4"},
                {"text": "Высокая (+5)", "value": "+5"},
                {"text": "Высокая (+6)", "value": "+6"}
